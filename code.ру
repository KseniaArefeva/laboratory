### 1. Проверка наличия элемента в массиве
def contains_item(collection, target):
    for item in collection:
        if item == target:
            return True
    return False

### 2. Поиск предпоследнего максимального значения
def find_second_largest(numbers):
    if len(numbers) < 2:
        return False
    largest = second = numbers[0]
    for num in numbers:
        if num > largest:
            second = largest
            largest = num
        elif num > second and num != largest:
            second = num
    return second

### 3. Двоичный поиск элемента
def binary_search(data, target):
    sorted_data = sorted(data)
    left_bound, right_bound = 0, len(sorted_data) - 1
    while left_bound <= right_bound:
        middle = (right_bound + left_bound) // 2
        if target > sorted_data[middle]:
            left_bound = middle + 1
        elif target < sorted_data[middle]:
            right_bound = middle - 1
        else:
            return True
    return False

### 4. Создание матрицы умножения
def create_multiplication_matrix(dimension):
    matrix = []
    for row_idx in range(1, dimension + 1):
        current_row = []
        for col_idx in range(1, dimension + 1):
            current_row.append(row_idx * col_idx)
        matrix.append(current_row)
    return matrix

### 5. Сортировка методом выбора
def selection_sort_algorithm(elements):
    elements = elements.copy()
    length = len(elements)
    for i in range(length):
        min_position = i
        for j in range(i + 1, length):
            if elements[j] < elements[min_position]:
                min_position = j
        elements[i], elements[min_position] = elements[min_position], elements[i]
    return elements

import time
def performance_measure(func, input_data):
    start = time.perf_counter()
    func(input_data)
    end = time.perf_counter()
    return end - start

import random

test_sizes = [10, 100, 1000, 10000]
print("1. Проверка наличия элемента в коллекции")
for size in test_sizes:
    test_array = list(range(size))
    random.shuffle(test_array)
    start = time.perf_counter()
    contains_item(test_array, -1)
    end = time.perf_counter()
    print(f"Размер {size}: {end - start:.8f} сек")

print("2. Поиск предпоследнего максимального значения")
for size in test_sizes:
    test_array = list(range(size))
    random.shuffle(test_array)
    start = time.perf_counter()
    find_second_largest(test_array)
    end = time.perf_counter()
    print(f"Размер {size}: {end - start:.8f} сек")

print("3. Двоичный поиск элемента")
for size in test_sizes:
    test_array = list(range(size))
    random.shuffle(test_array)
    start = time.perf_counter()
    binary_search(test_array, test_array[0])
    end = time.perf_counter()
    print(f"Размер {size}: {end - start:.8f} сек")

matrix_sizes = [10, 50, 100]
print("4. Создание матрицы умножения")
for size in matrix_sizes:
    start = time.perf_counter()
    create_multiplication_matrix(size)
    end = time.perf_counter()
    print(f"Размер {size}: {end - start:.8f} сек")

print("5. Сортировка методом выбора")
for size in test_sizes:
    test_array = list(range(size))
    random.shuffle(test_array)
    start = time.perf_counter()
    selection_sort_algorithm(test_array)
    end = time.perf_counter()
    print(f"Размер {size}: {end - start:.8f} сек")
